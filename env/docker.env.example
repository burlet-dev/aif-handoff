# ============================================================
# Env для интерполяции ${...} в самом compose-файле (НЕ для app-сервисов).
# Compose читает корневой .env. SOPS-вольт env/docker.env расшифровывается на
# сервере в корневой .env через scripts/sops-decrypt.sh.
# ============================================================

# Тег образов в GHCR, который тянет compose (sha-xxx из CI).
IMAGE_TAG=latest

# HOME используется для bind ${HOME}/aif/{projects,data}. Сервер задаёт сам.
# Здесь дублировать НЕ нужно — берётся из окружения деплой-юзера.
